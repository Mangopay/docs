{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Customer email insights. Availability of this data depends on the configuration of your account, please contact our <a href=\"mailto: support@nethone.com\">Support Team</a> for more details.",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "description": "Email",
      "examples": ["john.doe@gmail.com"]
    },
    "is_valid": {
      "type": ["boolean", "null"],
      "description": "Is valid?"
    },
    "is_disposable": {
      "type": ["boolean", "null"],
      "description": "Is disposable?"
    },
    "domain": {
      "type": ["string", "null"],
      "description": "Domain",
      "examples": ["gmail.com"]
    },
    "tld": {
      "type": ["string", "null"],
      "description": "Top-level domain",
      "examples": [".com"]
    },
    "domain_age_days": {
      "type": ["integer", "null"],
      "description": "Domain age (days)",
      "examples": [850]
    },
    "is_common_domain": {
      "type": ["boolean", "null"],
      "description": "Is common domain?"
    },
    "email_first_seen_days": {
      "type": ["integer", "null"],
      "description": "When email was first seen (days ago)",
      "examples": [320]
    },
    "is_autogenerated": {
      "type": ["boolean", "null"],
      "description": "Is autogenerated?"
    }
  },
  "required": [
    "email",
    "is_valid",
    "is_disposable",
    "domain",
    "tld",
    "domain_age_days",
    "is_common_domain",
    "email_first_seen_days",
    "is_autogenerated"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": ["string", "null"],
      "description": "Delivery method for the order",
      "enum": [
        "shipping_address",
        "pickup",
        "branch_shop",
        "parcel_locker",
        "electronic",
        "hq",
        null
      ]
    },
    "location_id": {
      "type": ["string", "null"],
      "description": "ID of a location where the package is delivered to",
      "minLength": 1,
      "maxLength": 2048
    },
    "personal_customer_number": {
      "type": ["string", "null"],
      "description": "The personal customer number used by Delivery company",
      "minLength": 1,
      "maxLength": 2048
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Other Payment Methods",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "enum": [
        "inapp",
        "sms",
        "blik",
        "applepay",
        "googlepay",
        "cash",
        "boleto",
        "pix",
        "ideal",
        "dotpay",
        "payconiq",
        "p24",
        "multibanco",
        "tink",
        "klarna",
        "satispay",
        "bancontact",
        "bizum",
        "pay_by_invoice",
        "eps",
        "twint",
        "swish",
        "zen",
        "upi",
        "net_banking",
        "wechat_pay",
        "grabpay",
        "paynow",
        "promptpay",
        "alipay",
        "poli",
        "paymaya",
        "shopeepay",
        "fpx",
        "ovo",
        "dana",
        "qris",
        "linkaja",
        "unionpay",
        "zondacrypto",
        "mybank",
        "aircash",
        "trustly",
        "neteller",
        "rapid_transfer",
        "epay",
        "paytrail",
        "cashtocode",
        "safetypay",
        "kakaopay",
        "oxxo",
        "pse",
        "volt"
      ],
      "description": "Determines the type of Payment Method"
    },
    "value": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Amount of money paid with this Payment Method" }
      ]
    },
    "extra_data": {
      "allOf": [
        { "$ref": "../common/extra_data.json" },
        {
          "description": "Additional data associated with this Payment Method (limited to 4kB by default)"
        }
      ]
    }
  },
  "required": ["method"]
}

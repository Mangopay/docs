{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Giftcard Payment",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "const": "giftcard",
      "description": "Determines the type of Payment Method - for giftcard payments must be a <code>giftcard</code> string"
    },
    "giftcard_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Giftcard ID hash",
      "examples": ["a3b3cdecf21332fdddef"]
    },
    "value": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Amount of money paid with this Payment Method" }
      ]
    },
    "extra_data": {
      "allOf": [
        { "$ref": "../common/extra_data.json" },
        {
          "description": "Additional data associated with this Payment Method (limited to 4kB by default)"
        }
      ]
    }
  },
  "required": ["method"]
}

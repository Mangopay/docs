{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loyalty program methods",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "enum": ["loyalty_program_points", "loyalty_program_punch_card"],
      "description": "Determines the type of Payment Method"
    },
    "card_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Name of the punch card used"
    },
    "value": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Amount of money paid with this Payment Method" }
      ]
    },
    "extra_data": {
      "allOf": [
        { "$ref": "../common/extra_data.json" },
        {
          "description": "Additional data associated with this Payment Method (limited to 4kB by default)"
        }
      ]
    }
  },
  "required": ["method"],
  "if": {
    "properties": { "method": { "const": "loyalty_program_points" } }
  },
  "then": {
    "not": { "required": ["card_name"] }
  }
}

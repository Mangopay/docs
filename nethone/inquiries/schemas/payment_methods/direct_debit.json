{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Direct debit",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "enum": ["sepa", "sofort", "giropay"],
      "description": "Determines the type of Payment Method - for Direct Debit payments must be a <code>sepa</code>, <code>sofort</code> or <code>giropay</code> string"
    },
    "payment_settlement": {
      "type": ["string", "null"],
      "enum": ["installment", "invoice", "delayed", "instant"]
    },
    "iban": {
      "deprecated": true,
      "$ref": "../common/iban.json",
      "description": "Use `account_number` field in `bank_account` instead."
    },
    "bank_account": {
      "$ref": "../common/bank_account.json"
    },
    "owner": {
      "id": {
        "type": ["string", "null"],
        "minLength": 1,
        "maxLength": 2048,
        "description": "Unique identifier of the person, if available"
      },
      "oneOf": [
        {
          "title": "Natural person",
          "allOf": [
            {
              "$ref": "../common/person.json#/$defs/natural_person_person_type"
            },
            { "$ref": "#/$defs/common_owner_props" },
            { "$ref": "../common/person.json" }
          ]
        },
        {
          "title": "Legal person",
          "allOf": [
            {
              "$ref": "../common/legal_person.json#/$defs/legal_person_person_type"
            },
            { "$ref": "#/$defs/common_owner_props" },
            { "$ref": "../common/legal_person.json" }
          ]
        }
      ]
    },
    "value": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Amount of money paid with this Payment Method" }
      ]
    },
    "extra_data": {
      "deprecated": true,
      "allOf": [
        { "$ref": "../common/extra_data.json" },
        {
          "description": "Additional data associated with this Payment Method (limited to 4kB by default)"
        }
      ]
    }
  },
  "required": ["method"],
  "$defs": {
    "common_owner_props": {
      "properties": {
        "id": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 2048,
          "description": "Unique identifier of the person, if available"
        }
      }
    }
  }
}

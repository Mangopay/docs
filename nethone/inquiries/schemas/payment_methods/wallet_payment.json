{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wallet Payment",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "const": "wallet_payment",
      "description": "Determines the type of Payment Method - for wallet payments must be a <code>wallet_payment</code> string"
    },
    "id": {
      "type": ["string", "null"],
      "description": "Wallet id or address",
      "maxLength": 2048
    },
    "balance": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Wallet balance after this Payment Method" }
      ]
    },
    "wallet": {
      "$ref": "../common/wallet.json"
    },
    "owner": {
      "id": {
        "type": ["string", "null"],
        "minLength": 1,
        "maxLength": 2048,
        "description": "Unique identifier of the person, if available"
      },
      "oneOf": [
        {
          "title": "Natural person",
          "allOf": [
            {
              "$ref": "../common/person.json#/$defs/natural_person_person_type"
            },
            { "$ref": "#/$defs/common_owner_props" },
            { "$ref": "../common/person.json" }
          ]
        },
        {
          "title": "Legal person",
          "allOf": [
            {
              "$ref": "../common/legal_person.json#/$defs/legal_person_person_type"
            },
            { "$ref": "#/$defs/common_owner_props" },
            { "$ref": "../common/legal_person.json" }
          ]
        }
      ]
    },
    "value": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Amount of money paid with this Payment Method" }
      ]
    }
  },
  "required": ["method"],
  "$defs": {
    "common_owner_props": {
      "properties": {
        "id": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 2048,
          "description": "Unique identifier of the person, if available"
        }
      }
    }
  }
}

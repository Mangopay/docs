{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": ["object"],
  "properties": {
    "address": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128,
      "description": "The wallet address associated with transaction"
    },
    "created_datetime": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Date and time of the wallet creation in ISO8601 format",
      "examples": ["2000-10-31T01:30:00.000-05:00"]
    },
    "type": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128,
      "description": "Wallet type",
      "examples": ["investment"]
    },
    "balance": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        { "description": "Wallet balance after the transaction" }
      ]
    }
  }
}

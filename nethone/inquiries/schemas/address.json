{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Addressee full name"
    },
    "first_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Addressee first name"
    },
    "last_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Addressee last name"
    },
    "courtesy_title": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Courtesy title of the addressee"
    },
    "country": {
      "$ref": "common/country.json"
    },
    "region": {
      "type": ["string", "null"],
      "examples": ["US-NY", "US-TX", "PL-14"],
      "description": "Name of the region (ISO 3166-2 subdivision) - ISO 3166-2 code preferred. Examples: US-TX for Texas in United States; PL-14 for Mazovia Voivodship in Poland, DE-NI for Niedersachsen Bundesland in Germany, BR-MG for Minas Gerais in Brazil",
      "minLength": 1,
      "maxLength": 7
    },
    "city": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "City"
    },
    "neighbourhood": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Neighbourhood"
    },
    "postal_code": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Postal code"
    },
    "po_box_number": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "PO box number"
    },
    "street": {
      "type": ["string", "null"],
      "examples": ["Madison Avenue"],
      "description": "Name of the street. It can include building and apartment number.",
      "minLength": 1,
      "maxLength": 2048
    },
    "building": {
      "type": ["string", "null"],
      "examples": ["16b"],
      "description": "Building number. Leave null if already provided with the street name",
      "minLength": 1,
      "maxLength": 2048
    },
    "apartment": {
      "type": ["string", "null"],
      "examples": ["2a"],
      "description": "Apartment number. Leave null if already provided with the street name",
      "minLength": 1,
      "maxLength": 2048
    },
    "latitude": {
      "type": ["number", "null"],
      "description": "Latitude",
      "examples": [52.233333]
    },
    "longitude": {
      "type": ["number", "null"],
      "description": "Longitude",
      "examples": [21.016667]
    },
    "extra_data": {
      "allOf": [
        { "$ref": "common/extra_data.json" },
        {
          "description": "Additional data associated with this address"
        }
      ]
    },
    "raw_data": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "address_line1": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "Original value of the street and street number of the address"
        },
        "address_line2": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "Additional address information"
        },
        "address_line3": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "Additional address information"
        },
        "country": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "ISO 3166-1 alpha-2 code"
        },
        "city": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "City"
        },
        "postal_code": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "description": "Postal code"
        }
      }
    }
  }
}

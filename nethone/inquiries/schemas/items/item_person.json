{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Unique identifier of the person, if available"
    },
    "first_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256,
      "description": "First name"
    },
    "middle_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256,
      "description": "Middle name"
    },
    "last_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256,
      "description": "Last name"
    },
    "phone_number": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128,
      "description": "Phone number"
    },
    "email": {
      "type": ["string", "null"],
      "format": "idn-email",
      "minLength": 3,
      "maxLength": 256,
      "description": "Email"
    },
    "type": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Natural person's type. E.g. `adult` or `child`",
      "examples": ["adult", "child"]
    },
    "dormant": {
      "type": ["boolean", "null"],
      "description": "Indicates whether the person has not been active for an extended period"
    },
    "gender": {
      "type": ["string", "null"],
      "enum": ["male", "female", "other", null],
      "description": "Person's gender"
    },
    "billing_address": {
      "$ref": "../address.json"
    },
    "registration_address": {
      "$ref": "../address.json"
    },
    "iban": {
      "$ref": "../common/iban.json"
    },
    "bank_name": {
      "type": ["string", "null"],
      "description": "Name of the bank, if applicable",
      "minLength": 1,
      "maxLength": 2048
    },
    "company_name": {
      "type": ["string", "null"],
      "description": "Name of the company, if applicable",
      "minLength": 1,
      "maxLength": 2048
    },
    "document_type": {
      "type": ["string", "null"],
      "description": "Type of ID document",
      "examples": ["passport", "country ID"],
      "minLength": 1,
      "maxLength": 2048
    },
    "date_of_birth": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date of birth in ISO8601 format",
      "examples": ["2020-11-25"]
    },
    "document_number": {
      "type": ["string", "null"],
      "description": "Number of the ID document",
      "minLength": 1,
      "maxLength": 2048
    },
    "document_issue_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Document issue date in ISO8601 format",
      "examples": ["2020-11-25"]
    },
    "document_issuing_authority": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Document issuing authority"
    },
    "document_issuing_state": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Document issuing state"
    },
    "nationality": {
      "$ref": "../common/country.json"
    },
    "country_of_birth": {
      "$ref": "../common/country.json"
    },
    "loyalty_program_id": {
      "type": ["string", "null"],
      "description": "Id of a loyalty program membership",
      "minLength": 1,
      "maxLength": 2048
    },
    "loyalty_program_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Loyalty program name",
      "examples": ["miles and more"]
    },
    "kyc_validated": {
      "type": ["boolean", "null"],
      "description": "Indicates whether or not the user is KYC validated"
    },
    "kyc_last_update_datetime": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Date and time of the last update for the Know Your Customer (KYC) information in ISO8601 format",
      "examples": ["2000-10-31T01:30:00.000-05:00"]
    },
    "country_of_residence": {
      "$ref": "../common/country.json"
    },
    "kyc_country_of_residence": {
      "$ref": "../common/country.json"
    },
    "pep_flag": {
      "type": ["boolean", "null"],
      "description": "Flag indicating whether the person is a Politically Exposed Person (PEP)"
    },
    "sanction_flag": {
      "type": ["boolean", "null"],
      "description": "Flag indicating whether the person is under sanction"
    },
    "is_blocked": {
      "type": ["boolean", "null"],
      "description": "Indicates whether the person is blocked."
    },
    "registration_datetime": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Date and time of the person's registration in ISO8601 format",
      "examples": ["2000-10-31T01:30:00.000-05:00"]
    },
    "last_update_datetime": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Date and time of the last update for the person's information in ISO8601 format",
      "examples": ["2000-10-31T01:30:00.000-05:00"]
    },
    "extra_data": {
      "$ref": "../common/extra_data.json"
    }
  }
}

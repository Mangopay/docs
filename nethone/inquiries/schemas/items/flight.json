{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flight",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "flight",
      "description": "Determines the type of Item - for flight items must be a <code>flight</code> string"
    },
    "id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Identifier of a product, if available"
    },
    "booking_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Identifier of the booking",
      "examples": ["Y6F9HG"]
    },
    "itinerary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "legs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "to": {
                      "type": ["string", "null"],
                      "pattern": "^[A-Z]{3}$",
                      "description": "Destination airport IATA code"
                    },
                    "from": {
                      "type": ["string", "null"],
                      "pattern": "^[A-Z]{3}$",
                      "description": "Origin airport IATA code"
                    },
                    "fare_base": {
                      "type": ["string", "null"],
                      "minLength": 1,
                      "maxLength": 2048,
                      "description": "Read more: https://en.wikipedia.org/wiki/Fare_basis_code"
                    },
                    "administrating_carrier": {
                      "type": ["string", "null"],
                      "minLength": 1,
                      "maxLength": 2048,
                      "description": "Administrating carrier"
                    },
                    "marketing_carrier": {
                      "type": ["string", "null"],
                      "minLength": 1,
                      "maxLength": 2048,
                      "description": "Marketing carrier"
                    },
                    "ticket_class": {
                      "type": ["string", "null"],
                      "minLength": 1,
                      "maxLength": 2048,
                      "description": "Ticket class",
                      "examples": ["Economic", "Business", "Economic Flex"]
                    },
                    "flight_number": {
                      "type": ["string", "null"],
                      "minLength": 1,
                      "maxLength": 2048,
                      "description": "Flight number"
                    },
                    "flight_duration": {
                      "type": ["string", "null"],
                      "description": "Flight duration in format 'hours:minutes' or 'hours:minutes:seconds'.",
                      "examples": ["01:20", "14:55", "99:59", "123:01:22"],
                      "pattern": "^[0-9]{2,}:[0-5][0-9](:[0-5][0-9])?$"
                    },
                    "arrival_datetime": {
                      "type": ["string", "null"],
                      "format": "date-time",
                      "description": "Arrival date and time as in RFC339 section 5.6",
                      "examples": ["2020-11-19T04:54:29+02:00"]
                    },
                    "departure_datetime": {
                      "type": ["string", "null"],
                      "format": "date-time",
                      "description": "Departure date and time as in RFC339 section 5.6",
                      "examples": ["2020-11-19T04:54:29+02:00"]
                    }
                  }
                }
              }
            }
          }
        },
        "refund_policy": {
          "type": ["string", "null"],
          "description": "Refund policy if the ticket is cancelled by the customer",
          "enum": ["fully refundable", "partially refundable", "non refundable", null]
        },
        "flight_type": {
          "type": ["string", "null"],
          "description": "Flight type",
          "enum": ["one way", "round trip", "multi city", null]
        }
      }
    },
    "passengers": {
      "type": "array",
      "description": "A list of passengers in the booking",
      "items": {
        "$ref": "item_person.json"
      }
    },
    "price": {
      "allOf": [
        { "$ref": "../../../common/money.json" },
        {
          "description": "Item's price"
        }
      ]
    },
    "extra_data": {
      "allOf": [
        { "$ref": "../common/extra_data.json" },
        {
          "description": "Additional data associated with this Item (limited to 4kB by default)"
        }
      ]
    }
  },
  "required": ["type"]
}

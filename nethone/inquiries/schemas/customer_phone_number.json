{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Customer phone number insights. Availability of this data depends on the configuration of your account, please contact our <a href=\"mailto: support@nethone.com\">Support Team</a> for more details.",
  "type": "object",
  "properties": {
    "phone_number": {
      "type": "string",
      "description": "Phone number",
      "examples": ["+48123456789"]
    },
    "is_valid": {
      "type": "boolean",
      "description": "Is valid?"
    },
    "carrier_name": {
      "type": ["string", "null"],
      "description": "Carrier name",
      "examples": ["T-Mobile"]
    },
    "country_code": {
      "type": ["string", "null"],
      "description": "ISO 3166-1 alpha-2 country code",
      "examples": ["PL", "US"]
    },
    "country_name": {
      "type": ["string", "null"],
      "description": "Country name",
      "examples": ["Poland", "United States"]
    }
  },
  "required": ["phone_number", "is_valid", "carrier_name", "country_code", "country_name"]
}

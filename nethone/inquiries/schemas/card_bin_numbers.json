{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Card BIN numbers' insights. Availability of this data depends on the configuration of your account, please contact our <a href=\"mailto: support@nethone.com\">Support Team</a> for more details.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "bin": {
        "type": "string",
        "description": "BIN number",
        "examples": ["123412", "12341234"]
      },
      "issuer_name": {
        "type": ["string", "null"],
        "description": "Issuer name",
        "examples": ["ACCLAIM FEDERAL CREDIT UNION"]
      },
      "country_code": {
        "type": ["string", "null"],
        "description": "ISO 3166-1 alpha-2 country code",
        "examples": ["PL", "US"]
      },
      "country_name": {
        "type": ["string", "null"],
        "description": "Country name",
        "examples": ["Poland", "United States"]
      },
      "brand": {
        "type": ["string", "null"],
        "description": "Card brand",
        "examples": ["AMERICAN EXPRESS"]
      },
      "type": {
        "type": ["string", "null"],
        "description": "Card type",
        "examples": ["CHARGE CARD", "DEBIT", "CREDIT"]
      },
      "level": {
        "type": ["string", "null"],
        "description": "Card level",
        "examples": ["PREPAID STUDENT", "PAYMENT CARD", "PREPAID CORPORATE/PREPAID"]
      },
      "pan_length": {
        "type": ["integer", "null"],
        "description": "Card PAN length",
        "examples": [15, 19]
      },
      "category": {
        "type": ["string", "null"],
        "description": "Card category",
        "examples": ["PERSONAL", "COMMERCIAL"]
      }
    },
    "required": ["bin", "issuer_name", "country_code", "country_name", "brand", "type", "level"]
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "partner_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Name of the marketing partner (e.g. agency or affiliate network)"
    },
    "campaign_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Name of the campaign"
    },
    "channel": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048,
      "description": "Name of the channel"
    },
    "cashier_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048
    },
    "pos_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048
    },
    "store_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048
    },
    "store_name": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the store where purchase was made. Should be recognizable to the consumer (not a parent company or non-consumer facing company name)"
    },
    "channel_reference": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 2048
    },
    "extra_data": {
      "$ref": "common/extra_data.json"
    }
  }
}

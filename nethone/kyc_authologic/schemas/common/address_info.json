{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "text": {
      "maxLength": 200,
      "minLength": 0,
      "type": "string",
      "description": "User's full address, not broken down into components.<br/><br/><b>Note:</b> This field has no format defined.",
      "example": "ul. Wiśniowa 133/20 00-950 Warszawa PL"
    },
    "addressLine": {
      "maxLength": 200,
      "minLength": 0,
      "type": "string",
      "description": "User address.",
      "example": "ul. Wiśniowa 133/20"
    },
    "postalCode": {
      "maxLength": 10,
      "minLength": 0,
      "type": "string",
      "description": "Postcode.",
      "example": "00-950"
    },
    "city": {
      "maxLength": 50,
      "minLength": 0,
      "type": "string",
      "description": "City.",
      "example": "Warszawa"
    }
  },
  "description": "User address."
}

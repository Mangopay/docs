{
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema",
  "additionalProperties": false,
  "required": ["reference"],
  "properties": {
    "reference": {
      "type": "string",
      "description": "Unique reference for this Subscription",
      "maxLength": 128
    },
    "user_reference": {
      "type": "string",
      "description": "Unique reference for this user",
      "maxLength": 64
    },
    "inquiry_id": {
      "type": "integer",
      "format": "int64",
      "description": "inquiry_id"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "flags": {
      "$ref": "flags_node.json"
    },
    "extra_data": {
      "type": "object",
      "description": "Additional information about subscription"
    }
  }
}

{
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "user_reference": {
      "type": "string",
      "description": "Unique user identifier, see <a href='/docs/integration_guide/faq#user_ref'>user_reference</a>. "
    },
    "profiling_reference": {
      "type": "string",
      "description": "Session identifier, see <a href='/docs/integration_guide/faq#prof_ref'>profiling_reference</a>.",
      "maxLength": 64
    },
    "timestamp": {
      "type": "string",
      "description": "timestamp indicating when this event occurred; supported format is <code>YYYY-MM-DD&nbsp;HH:MM:SS+HH:MM</code>; time zone info (<code>+HH:MM</code>) can be skipped in which case it is assumed that the value is in UTC"
    },
    "data": {
      "type": "object",
      "description": "Data set associated with event  (limited to 4kB by default)",
      "maxLength": 1024
    },
    "type": {
      "type": "string",
      "maxLength": 64,
      "description": { "$ref": "event_types.html" }
    }
  }
}

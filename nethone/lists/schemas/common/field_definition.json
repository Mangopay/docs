{
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema",
  "required": ["name", "type"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of this field",
      "example": "User IP Address"
    },
    "type": {
      "$ref": "./field_type.json",
      "title": "Type of data for this field",
      "example": "IP_ADDRESS"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "required": ["id", "id_str", "name"],
  "properties": {
    "id": {
      "type": "number",
      "examples": [1494024],
      "description": "User ID"
    },
    "id_str": {
      "type": "string",
      "description": "Copies the value from corresponding id field as string. Use to avoid JS rounding problems.",
      "examples": ["1494024"]
    },
    "name": {
      "type": "string",
      "format": "email",
      "description": "Name of the user"
    }
  }
}

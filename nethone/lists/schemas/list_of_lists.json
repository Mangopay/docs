{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "List of lists",
  "additionalProperties": false,
  "type": "object",
  "required": ["page_number", "page_size", "objects_count", "objects"],
  "properties": {
    "page_number": {
      "type": "number",
      "description": "Page number",
      "examples": [1]
    },
    "page_size": {
      "type": "number",
      "description": "Page size",
      "examples": [10]
    },
    "objects_count": {
      "type": "number",
      "description": "Total number of lists in application",
      "examples": [45]
    },
    "objects": {
      "type": "array",
      "description": "Returned lists matching criteria",
      "items": {
        "$ref": "./post_list_response.json"
      }
    }
  }
}

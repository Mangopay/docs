{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Modify item",
  "additionalProperties": false,
  "type": "object",
  "required": ["op", "id"],
  "properties": {
    "op": {
      "type": "string",
      "const": "modify"
    },
    "id": {
      "type": "number",
      "examples": [1494024],
      "description": "Item ID"
    },
    "values": {
      "$ref": "./common/values.json"
    },
    "expires_at": {
      "$ref": "./common/expires_at.json"
    },
    "comment": {
      "$ref": "./common/comment.json"
    }
  }
}

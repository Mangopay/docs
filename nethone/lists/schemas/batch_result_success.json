{
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item list",
  "additionalProperties": false,
  "required": ["op_results"],
  "properties": {
    "op_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["idx"],
        "properties": {
          "idx": {
            "type": "number",
            "title": "Index",
            "description": "A number corresponding to the order in the batch update. 0-based."
          },
          "id": {
            "type": "number",
            "examples": [1494024],
            "description": "Item ID"
          },
          "id_str": {
            "type": "string",
            "description": "Copies the value from corresponding id field as string. Use to avoid JS rounding problems.",
            "examples": ["1494024"]
          }
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "List item",
  "additionalProperties": false,
  "required": [
    "id",
    "id_str",
    "values",
    "list_id",
    "list_id_str",
    "created_at",
    "expires_at",
    "expired",
    "created_by",
    "comment"
  ],
  "properties": {
    "id": {
      "type": "number",
      "examples": [1494024],
      "description": "Item ID"
    },
    "id_str": {
      "type": "string",
      "description": "Copies the value from corresponding id field as string. Use to avoid JS rounding problems.",
      "examples": ["1494024"]
    },
    "values": {
      "$ref": "./common/values.json"
    },
    "list_id": {
      "type": "number",
      "examples": [1494024],
      "description": "List ID"
    },
    "list_id_str": {
      "type": "string",
      "description": "Copies the value from corresponding id field as string. Use to avoid JS rounding problems.",
      "examples": ["1494024"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Item creation date as ISO-8601 string"
    },
    "expires_at": {
      "$ref": "common/expires_at.json"
    },
    "expired": {
      "type": "boolean",
      "description": "Information if the item has already expired"
    },
    "created_by": {
      "$ref": "./common/user.json",
      "description": "User who created the item"
    },
    "comment": {
      "$ref": "./common/comment.json"
    }
  }
}

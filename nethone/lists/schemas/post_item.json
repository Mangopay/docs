{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Add item to list",
  "additionalProperties": false,
  "type": "object",
  "required": ["list_id", "values"],
  "properties": {
    "list_id": {
      "type": "number",
      "examples": [1494024],
      "description": "Id of the list for the new element"
    },
    "values": {
      "$ref": "./common/values.json"
    },
    "expires_at": {
      "$ref": "./common/expires_at.json"
    },
    "comment": {
      "$ref": "./common/comment.json"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item list",
  "additionalProperties": false,
  "type": "object",
  "required": ["page_number", "page_size", "objects_count", "objects"],
  "properties": {
    "page_number": {
      "type": "number",
      "description": "Page number",
      "examples": [1]
    },
    "page_size": {
      "type": "number",
      "description": "Page size",
      "examples": [100]
    },
    "objects_count": {
      "type": "number",
      "description": "Total number of items in list",
      "examples": [13421]
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "./item.json"
      }
    }
  }
}
